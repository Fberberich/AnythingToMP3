{
  "name": "audio-converter",
  "version": "1.0.0",
  "description": "Local web app to convert M4A and video files to MP3",
  "type": "module",
  "main": "electron/main.js",
  "author": "Frederick Berberich <Fredberbs3@gmail.com",
  "scripts": {
    "copy-lib": "node copy-lib.js",
    "start": "node copy-lib.js && node server.js",
    "dev": "node copy-lib.js && node server.js",
    "build": "npm run copy-lib && electron-builder",
    "build:win": "npm run copy-lib && electron-builder --win",
    "build:linux": "npm run copy-lib && electron-builder --linux"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.6",
    "@ffmpeg/ffmpeg": "^0.12.10",
    "@ffmpeg/util": "^0.12.1",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.audioconverter.app",
    "productName": "Audio to MP3 Converter",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**",
      "public/**",
      "server.js",
      "package.json"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "category": "AudioVideo"
    }
  }
}
